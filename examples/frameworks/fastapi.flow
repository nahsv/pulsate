# FastAPI / Uvicorn (Python ASGI) behind Pulsate
# =================================================================
# End-to-end: a FastAPI service with auto HTTPS, CORS, rate limiting,
# WebSockets, and gzip — replacing nginx in front of Uvicorn/Gunicorn.
#
# STEPS
#   1. Run Uvicorn (or Gunicorn w/ uvicorn workers) on loopback:
#        uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 4
#      Add ProxyHeadersMiddleware / --proxy-headers so request.url is https.
#   2. Point DNS for api.example.com at this host.
#   3. p8 validate examples/frameworks/fastapi.flow
#      sudo p8 up examples/frameworks/fastapi.flow
#   4. Verify docs:  open https://api.example.com/docs
# =================================================================

upstream uvicorn {
  target http://127.0.0.1:8000
  policy least_conn
  retry { attempts 2 }
}

site api.example.com {
  tls auto

  route = /health ~> respond(status=200, body="ok")

  # WebSocket routes (FastAPI @app.websocket).
  route /ws/* ~> ws(@uvicorn)

  route /* ~> cors(origins=["https://app.example.com"], methods=[GET, POST, PUT, PATCH, DELETE])
           ~> rate_limit(600/min, key=ip)
           ~> compress
           ~> proxy(@uvicorn)
}
